# Environment variables
# Rename this file to .env and fill in the values

# Gmail App Password (if using Gmail SMTP)
PASSWORD=your_gmail_app_password_here

# Email address used to send notifications
EMAIL_SENDER=your_email@gmail.com

# McMaster MyTimetable Credentials
MYTIMETABLE_USERNAME=your_mcmaster_username
MYTIMETABLE_PASSWORD=your_mcmaster_password
